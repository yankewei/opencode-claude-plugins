{
  "name": "opencode-claude-plugins",
  "version": "0.1.2",
  "description": "Use Claude Code plugins inside opencode — a minimal compatibility plugin",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "claude-code",
    "plugin",
    "compat",
    "mcp",
    "hooks"
  ],
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^26.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
