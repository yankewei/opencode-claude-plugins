{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ESNext"],
    "types": ["node"],
    "paths": {
      "@opencode-ai/plugin": ["./node_modules/@opencode-ai/plugin"]
    }
  },
  "include": ["src/**/*.ts", ".opencode/plugins/**/*.ts"]
}
